#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char str[200], ch;
    int i, freq = 0, words = 0;
    int alphabet[26] = {0};

    printf("Enter string: ");
    fgets(str, sizeof(str), stdin);

    printf("Enter character to find frequency: ");
    scanf("%c", &ch);

    for (i = 0; str[i] != '\0'; i++) {
        if (str[i] == ch)
            freq++;

        if ((i == 0 && str[i] != ' ') || (str[i] == ' ' && str[i+1] != ' ' && str[i+1] != '\0'))
            words++;

        if (isalpha(str[i]))
            alphabet[tolower(str[i]) - 'a']++;
    }

    printf("Frequency of '%c': %d\n", ch, freq);
    printf("Number of words: %d\n", words);

    printf("Alphabet frequencies:\n");
    for (i = 0; i < 26; i++) {
        if (alphabet[i] > 0)
            printf("%c = %d\n", i + 'a', alphabet[i]);
    }

    return 0;
}
