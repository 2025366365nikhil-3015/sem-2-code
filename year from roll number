#include <stdio.h>

int extractYear(char roll[]) {
    int year = 0;
    for (int i = 0; i < 4; i++) {
        year = year * 10 + (roll[i] - '0');
    }
    return year;
}

int main() {
    char roll[20];

    printf("Enter Roll Number: ");
    scanf("%s", roll);

    printf("Year of Admission: %d\n", extractYear(roll));

    return 0;
}
